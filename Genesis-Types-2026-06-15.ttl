@base <http://w3id.org/arkumu/genesis-types> .
@prefix schema: <http://schema.org/> .
@prefix adms: <http://www.w3.org/ns/adms#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xls2rdf: <https://xls2rdf.sparna.fr/vocabulary#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skosthes: <http://purl.org/iso25964/skos-thes#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix qb: <http://purl.org/linked-data/cube#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix doap: <http://usefulinc.com/ns/doap#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix genesis-type: <http://w3id.org/arkumu/genesis-types/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix euvoc: <http://publications.europa.eu/ontology/euvoc#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosxl: <http://www.w3.org/2008/05/skos-xl#> .

<> a skos:ConceptScheme;
  dct:title "Genesis Types"@en, "Entstehungstypen"@de;
  dct:description "Der Entstehungstyp beschreibt, ob ein Digitales Objekt ursprünglich digital erzeugt wurde oder ob es sich um eine digitalisierte Kopie eines bereits existierenden Informationsträgers handelt"@de,
    "The Genesis Type indicates whether a digital object was originally created in digital form or whether it is a digitized copy of an existing Information Storage Medium"@en;
  dct:created "2026-06-15"^^xsd:date;
  skos:editorialNote "URI noch zu klären"@de;
  dct:license <https://creativecommons.org/publicdomain/zero/1.0/>;
  skos:hasTopConcept genesis-type:born-digital, genesis-type:retro-digitised .

genesis-type:born-digital a skos:Concept;
  skos:notation "1";
  skos:prefLabel "Born Digital"@en, "Born Digital"@de;
  skos:inScheme <>;
  skos:topConceptOf <> .

genesis-type:retro-digitised a skos:Concept;
  skos:notation "2";
  skos:prefLabel "Retro-Digitised"@en, "Retrodigitalisat"@de;
  skos:inScheme <>;
  skos:topConceptOf <> .
