media-type:image a skos:Concept;
  skos:notation "3";
  skos:prefLabel "Image"@en, "Bild"@de;
  skos:inScheme <>;
  skos:topConceptOf <> .

media-type:text a skos:Concept;
  skos:notation "4";
  skos:prefLabel "Text"@en, "Text"@de;
  skos:inScheme <>;
  skos:topConceptOf <> .

media-type:video a skos:Concept;
  skos:notation "5";
  skos:prefLabel "Video"@en, "Video"@de;
  skos:inScheme <>;
  skos:topConceptOf <> .

media-type:code a skos:Concept;
  skos:notation "6";
  skos:prefLabel "Code"@en, "Code"@de;
  skos:inScheme <>;
  skos:topConceptOf <> .

media-type:data a skos:Concept;
  skos:notation "7";
  skos:prefLabel "Data"@en, "Daten"@de;
  skos:inScheme <>;
  skos:topConceptOf <> .
