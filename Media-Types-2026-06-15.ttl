<> a skos:ConceptScheme;
  dct:title "Media Types"@en, "Medientypen"@de;
  dct:description "Der Medientyp erlaubt eine Kategorisierung einer Datei. Die Medientypen \"3D\", \"Audio\", \"Bild\", \"Text\" und \"Video\" stammen dabei aus der [Kategorisierung der Deutschen Digitalen Bibliothek](https://pro.deutsche-digitale-bibliothek.de/glossar/medientyp) und wurden um die Medientypen \"Code\" und \"Daten\" erweitert. Im Gegensatz zur DDB ist das Format der Mediendatei für diese Einordnung entscheidend und kann damit durch die einfache Erkennung des Mime-Types automatisiert werden."@de,
    "The Media Type allows for a file to be categorized. The Media Types \"3D\", \"Audio\", \"Image\", \"Text\", and \"Video\" originate from the [categorisation of the Deutsche Digitale Bibliothek (German Digital Library)](https://pro.deutsche-digitale-bibliothek.de/glossar/medientyp) and have been expanded to include the Media Types \"Code\" and \"Data\". In contrast to the DDB this classification is based on the file format and can therefore be automated based on the file's MIME-Type."@en;
  dct:created "2026-06-15"^^xsd:date;
  skos:editorialNote "URI noch zu klären"@de;
  dct:license <https://creativecommons.org/publicdomain/zero/1.0/>;
  skos:hasTopConcept media-type:3d, media-type:audio, media-type:image, media-type:text,
    media-type:video, media-type:code, media-type:data .

media-type:3d a skos:Concept;
  skos:notation "1";
  skos:prefLabel "3D"@en, "3D"@de;
  skos:inScheme <>;
  skos:topConceptOf <> .

media-type:audio a skos:Concept;
  skos:notation "2";
  skos:prefLabel "Audio"@en, "Audio"@de;
  skos:inScheme <>;
